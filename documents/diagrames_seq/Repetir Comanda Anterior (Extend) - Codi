@startuml
skinparam maxMessageSize 150

actor Comprador
boundary "Interficie\nComanda" as Interficie
control "Gestor\nComanda" as Gestor
entity "Dades\nComprador" as DadesComprador
entity "Comanda" as Comanda
entity "Dades\nCuiner" as DadesCuiner
control "Gestor\nBanc" as GestorBanc
control "Gestor\nMaps" as GestorMaps
boundary "Interficie\nBanc" as InterficieBanc
boundary "Interficie\nMaps" as InterficieMaps
actor "Entidad\nBancaria\n«actor externo»" as Banco
actor "Google\nMaps\n«actor externo»" as Maps

Comprador -> Interficie: realitzar_comanda()
activate Interficie

Interficie -> Gestor: realitzar_comanda()
activate Gestor

Gestor -> DadesComprador: obtener_historial()
activate DadesComprador
DadesComprador --> Gestor: «return»
deactivate DadesComprador

Gestor -> Comanda: seleccionar_comanda_repetida()
activate Comanda
Comanda --> Gestor: «return»
deactivate Comanda

Gestor -> DadesCuiner: comprovar_disponibilitat()
activate DadesCuiner
DadesCuiner --> Gestor: «return»
deactivate DadesCuiner

Gestor --> Interficie: mostrar_disponibilitat()

alt if_disponible
    Comprador -> Interficie: afegir_pagament()
    Interficie -> Gestor: afegir_pagament()
    
    ' --- FLUX BANCARI CORREGIT ---
    Gestor -> GestorBanc: validar_pagament()
    activate GestorBanc
    
    GestorBanc -> InterficieBanc: validar_pagament()
    activate InterficieBanc
    
    
    Banco --> InterficieBanc: confirmacio()
   
    
    InterficieBanc --> GestorBanc: confirmacio()
    deactivate InterficieBanc
    
    GestorBanc --> Gestor: confirmacio()
    deactivate GestorBanc

    Gestor -> Comanda: actualitza_pagament()
    activate Comanda
    Comanda --> Gestor: «return»
    deactivate Comanda

    ' --- FLUX MAPS AFEGIT I ESTRUCTURAT ---
    Comprador -> Interficie: afegir_direcció()
    Interficie -> Gestor: afegir_direcció()
    
    Gestor -> GestorMaps: validar_direcció(adreça)
    activate GestorMaps
    
    GestorMaps -> InterficieMaps: validar_direcció(adreça)
    activate InterficieMaps
    
    Maps --> InterficieMaps: donar_coordenades()
    
    InterficieMaps --> GestorMaps: «return» coordenades
    deactivate InterficieMaps
    
    GestorMaps --> Gestor: «return» coordenades
    deactivate GestorMaps
    
    Gestor -> Comanda: actualitza_direcció(coordenades)
    activate Comanda
    Comanda --> Gestor: «return»
    deactivate Comanda

    Interficie -> Gestor: finalitzar_comanda()

else if_no_disponible
    Interficie -> Gestor: abortar_comanda()
end

deactivate Gestor
deactivate Interficie

@enduml
