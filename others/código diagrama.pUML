@startuml

' --- ENUMS ---
enum EstatComanda {
    PENDENT_PREPARACIO
    EN_PREPARACIO
    EN_CAMI
    ENTREGADA
    CANCEL_LADA
}

enum ModalitatEntrega {
    REPARTIDOR_APP
    PROPI_CUINER
    RECOLLIDA_CLIENT
}

' --- CAPA BOUNDARY (INTERFÍCIES DE LÍMIT) ---
class InterfUsuaris <<boundary>> {
}

class InterfComprador <<boundary>> {
}

class InterfCuiner <<boundary>> {
}

class InterfRepartidor <<boundary>> {
}

class InterfComandes <<boundary>> {
}

class InterfCataleg <<boundary>> {
}

class InterfComunicacio <<boundary>> {
}


' --- CAPA CONTROL (GESTORS) ---
class CtrlUsuaris <<control>> {
    + registrarUsuari(dades: DadesUsuariRegistrat)
    + autenticarUsuari(correu: String, pass: String): DadesUsuariRegistrat
}

class CtrlComprador <<control>> {
}

class CtrlCuiner <<control>> {
}

class CtrlRepartidor <<control>> {
}

class CtrlComandes <<control>> {
    + crearComanda(idComprador: int, idMenu: int, mod: ModalitatEntrega): Comanda
    + processarPagament(idComanda: int, metode: String): boolean
    + actualitzarEstat(idComanda: int, estat: EstatComanda)
    + obtenirRutaRepartiment(idComanda: int)
}

class CtrlCataleg <<control>> {
    + afegirMenu(idCuiner: int, menu: Menú)
    + afegirPropostaMenu(idComprador: int, proposta: String)
}

class CtrlComunicacio <<control>> {
    + iniciarXat(idUsuari1: int, idUsuari2: int): Xat
    + enviarMissatge(idXat: int, idEmisor: String, text: String)
}


' --- CAPA ENTITAT (CLASSES DE DOMINI ORIGINALS) ---
class DadesUsuariRegistrat <<entity>> {
    - idUsuari: int
    - nom: String
    - correu: String
    - contrasenya: String
    - adreçaRecollida: String
    + daseDeBaixa()
    + loguejar-se()
}

class DadesComprador <<entity>> {
    - restriccionsAlimentaries: List<String>
    - teSubscripcio: boolean
    - puntsAcumulats: int
    + realitzarComanda()
    + valorarComanda()
    + desitjarMenú(nomMenu: String, detalls: String)
    + consultarMenús()
}

class DadesCuiner <<entity>> {
    - rankingPosicio: int
    - disponible: boolean
    + indicarDisponibilitat(estat: boolean)
    + gestionarCataleg()
    + consultarPlatsDesitjats()
}

class DadesRepartidor <<entity>> {
    - localitzacioActual: String
    + actualitzarPosicio()
}

class Comanda <<entity>> {
    - idComanda: int
    - data: Date
    - estat: EstatComanda
    - modalitat: ModalitatEntrega
    - preuTotal: double
    + calcularPreuTotal(): double
    + actulitzarEstat(EstatComanda estatActualitzat)
}

class Menú <<entity>> {
    - idMenu: int
    - nom: String
    - preu: double
}

class Plat <<entity>> {
    - idPlat: int
    - nom: String
    - tempsEstimatEntrega: int
}

class Ingredient <<entity>> {
    - nom: String
    - esOpcional: boolean
    - esAl_lergen: boolean
}

class Valoracio <<entity>> {
    - puntuacio: int
    - puntualitatEntrega: int
    - estatMenjar: int
    - comentari: String
}

class Xat <<entity>> {
    - idXat: int
    + enviarMissatge(text: String)
}

class Missatge <<entity>> {
    - Data: Date
    - Contingut: String
    - idMissatge: String
    - idEmisor: String
    + editarMissatge(text: String)
}


' --- RELACIONS ---

' Herència Entitats (mantenim original)
DadesUsuariRegistrat <|-- DadesComprador
DadesUsuariRegistrat <|-- DadesCuiner
DadesUsuariRegistrat <|-- DadesRepartidor

' Relacions d'Entitats (mantenim original de la teva foto)
DadesComprador "1" --> "0..*" Comanda : realitza
DadesCuiner "1" --> "0..*" Comanda : prepara
DadesRepartidor "0..1" --> "0..*" Comanda : lliura
Comanda "0.." --> "1.." Menú : inclou
Comanda --> EstatComanda : té estat
Comanda --> ModalitatEntrega : s'entrega via
DadesCuiner "1" --> "0..*" Menú : ofereix
Menú "1" o-- "1..*" Plat : conté
Plat "1" o-- "1..*" Ingredient : té
DadesComprador --> Menú : proposa 
DadesCuiner --> Menú : consulta propostes 
DadesComprador "1" --> "0..*" Valoracio : crea
Valoracio "0..*" --> "1" DadesCuiner : puntua
DadesComprador "1" -- "0..*" Xat
DadesCuiner "1" -- "0..*" Xat
Missatge "0.." -- "1" Xat


' --- RELACIONS DE LES NOVES CAPES (PATRÓ DEMANAT) ---

' Gestió d'Usuaris General
InterfUsuaris "1" -- "1" CtrlUsuaris
CtrlUsuaris "1" -- "1..*" DadesUsuariRegistrat

' Gestió Específica del Comprador
InterfComprador "1" -- "1" CtrlComprador
CtrlComprador "1" -- "1..*" DadesComprador

' Gestió Específica del Cuiner
InterfCuiner "1" -- "1" CtrlCuiner
CtrlCuiner "1" -- "1..*" DadesCuiner

' Gestió Específica del Repartidor
InterfRepartidor "1" -- "1" CtrlRepartidor
CtrlRepartidor "1" -- "1..*" DadesRepartidor

' Gestió de Comandes
InterfComandes "1" -- "1" CtrlComandes
CtrlComandes "1" -- "1..*" Comanda

' Gestió del Catàleg
InterfCataleg "1" -- "1" CtrlCataleg
CtrlCataleg "1" -- "1..*" Menú
CtrlCataleg "1" -- "1..*" Plat

' Gestió de Comunicació
InterfComunicacio "1" -- "1" CtrlComunicacio
CtrlComunicacio "1" -- "1..*" Xat

@enduml
