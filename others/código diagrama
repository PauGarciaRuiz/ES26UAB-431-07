@startuml

' --- ENUMS ---
enum EstatComanda {
    PENDENT_PREPARACIO
    EN_PREPARACIO
    EN_CAMI
    ENTREGADA
    CANCEL_LADA
}

enum ModalitatEntrega {
    REPARTIDOR_APP
    PROPI_CUINER
    RECOLLIDA_CLIENT
}


class UsuariRegistrat {
    - idUsuari: int
    - nom: String
    - correu: String
    - contrasenya: String
    - adreçaRecollida: String
    + daseDeBaixa()
    + loguejar-se()
}

' --- ROLS D'USUARI REGISTRAT (RF-1-04) ---
class Comprador {
    - restriccionsAlimentaries: List<String>
    - teSubscripcio: boolean
    - puntsAcumulats: int
    + realitzarComanda()
    + valorarComanda()
    + desitjarMenú(nomMenu: String, detalls: String)
    + consultarMenús()
}

class Cuiner {
    - rankingPosicio: int
    - disponible: boolean
    + indicarDisponibilitat(estat: boolean)
    + gestionarCataleg()
    + consultarPlatsDesitjats()
}

class Repartidor {
    - localitzacioActual: String
    + actualitzarPosicio()
}

' --- CORE DEL NEGOCI ---
class Comanda {
    - idComanda: int
    - data: Date
    - estat: EstatComanda
    - modalitat: ModalitatEntrega
    - preuTotal: double
    + calcularPreuTotal(): double
    + actulitzarEstat(EstatComanda estatActualitzat)
}

class Menú {
    - idMenu: int
    - nom: String
    - preu: double
}

class Plat {
    - idPlat: int
    - nom: String
    - tempsEstimatEntrega: int
}

class Ingredient {
    - nom: String
    - esOpcional: boolean
    - esAl_lergen: boolean
}

class Valoracio {
    - puntuacio: int
    - puntualitatEntrega: int
    - estatMenjar: int
    - comentari: String
}

class Xat {
    - idXat: int
    + enviarMissatge(text: String)
}

' --- SERVEIS EXTERNS (INTERFICIES) ---
class ServeiPagament <<service>> {
    + autenticarPagament(import: double, metode: String): boolean
}

class ServeiGPS <<service>> {
    + calcularDistancia(origen: String, desti: String): double
    + mostrarMapaSeguiment()
}

' --- RELACIONS ---


' Els rols penjant de l'usuari registrat
UsuariRegistrat <|-- Comprador
UsuariRegistrat <|-- Cuiner
UsuariRegistrat <|-- Repartidor

' Relacions de Comandes
Comprador "1" --> "0..*" Comanda : realitza
Cuiner "1" --> "0..*" Comanda : prepara
Repartidor "0..1" --> "0..*" Comanda : lliura

' El contingut de les comandes
Comanda "0..*" --> "1..*" Menú : inclou

' Vinculació dels Enums a la Comanda
Comanda ..> EstatComanda : té estat
Comanda ..> ModalitatEntrega : s'entrega via

' Composició de Menús i Plats
Cuiner "1" --> "0..*" Menú : ofereix
Menú "1" *-- "1..*" Plat : conté
Plat "1" o-- "1..*" Ingredient : té

' Funcionalitat de Plats Desitjats (RF-6-01: El comprador desitja un menú/plat que el cuiner pot veure)
Comprador ..> Menú : proposa 
Cuiner ..> Menú : consulta propostes 

' Valoracions
Comprador "1" --> "0..*" Valoracio : crea
Valoracio "0..*" --> "1" Cuiner : puntua

' Comunicació
Comprador "1" -- "0..*" Xat
Cuiner "1" -- "0..*" Xat

' Dependències de Serveis Externs
Comprador ..> ServeiPagament : paga a través de
Comanda ..> ServeiGPS : utilitza

@enduml
